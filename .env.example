# LiteLLM Proxy Credentials
# Rename this file to .env and fill in your keys

# UI Login Credentials
# IMPORTANT: LITELLM_MASTER_KEY must start with 'sk-'
LITELLM_MASTER_KEY=sk-free-frontier-1234
LITELLM_UI_PASSWORD=admin123

# Cloud Providers

# Google AI Studio (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key

# GitHub Models Marketplace (https://github.com/marketplace/models)
# Use a GitHub Personal Access Token (Classic or Fine-grained)
GITHUB_TOKEN=your_github_token

# Groq Cloud (https://console.groq.com/keys)
GROQ_API_KEY=your_groq_api_key

# OpenRouter (https://openrouter.ai/keys)
OPENROUTER_API_KEY=your_openrouter_api_key

# NVIDIA NIM (https://build.nvidia.com/nvidia/deepseek-v3)
NVIDIA_NIM_API_KEY=your_nvidia_nim_api_key
